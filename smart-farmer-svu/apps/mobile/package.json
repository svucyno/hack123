{
  "name": "smart-farmer-mobile",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "prestart": "node ./scripts/free-expo-port.js",
    "prestart:clear": "node ./scripts/free-expo-port.js",
    "prestart:lan": "node ./scripts/free-expo-port.js",
    "prestart:tunnel": "node ./scripts/free-expo-port.js",
    "start": "expo start --clear --lan --go",
    "start:clear": "expo start --clear --lan --go",
    "start:lan": "expo start --clear --lan --go",
    "start:tunnel": "expo start --clear --tunnel --go",
    "android": "expo start --android --go",
    "ios": "expo start --ios --go",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.0",
    "expo-image-picker": "~17.0.8",
    "expo-location": "~19.0.7",
    "expo-notifications": "~0.32.11",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
