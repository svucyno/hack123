{
  "name": "smart-farmer-expo",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "prestart": "node ./scripts/free-expo-port.js",
    "prestart:clear": "node ./scripts/free-expo-port.js",
    "prestart:tunnel": "node ./scripts/free-expo-port.js",
    "start": "expo start --clear --lan",
    "start:clear": "expo start --clear --lan",
    "start:tunnel": "expo start --clear --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~54.0.0",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.4"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
